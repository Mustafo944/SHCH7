# Supabase Configuration
# You can find these values in your Supabase Project Settings -> API

# Public API URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Public Anon Key (safe to use in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------
# SECURITY WARNING: DANGER ZONE
# ---------------------------------------------------------
# Service Role Key (DO NOT expose to the frontend!)
# This key bypasses Row Level Security (RLS) entirely.
# Use ONLY in server-side functions (e.g. app/api/admin/...)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------------------------------------------------------
# Rele-nazorat integration (separate deployed project)
# ---------------------------------------------------------
NEXT_PUBLIC_RELE_SUPABASE_URL=https://vebhjxwzpqdwxbtquyth.supabase.co
NEXT_PUBLIC_RELE_SUPABASE_ANON_KEY=your_relenazorat_anon_key
NEXT_PUBLIC_RELE_SITE_URL=https://relenazorat.vercel.app
